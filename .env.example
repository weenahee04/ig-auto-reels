# ===== Instagram (Official API: "Instagram API with Instagram Login") =====
# long-lived access token (อายุ 60 วัน ต่ออายุด้วย npm run token:refresh)
IG_ACCESS_TOKEN=

# ===== Optional =====
# ใส่ @handle ของคุณ ไว้โชว์มุมขวาบนของคลิป (เว้นว่าง = ไม่โชว์)
BRAND_HANDLE=
# ความยาวคลิป (วินาที) 8-30 แนะนำ 12
REC_SECONDS=12
# เลือกคอมโพเนนต์: random (สุ่มจาก 12 อันดับแรกที่ยังไม่เคยโพสต์) | top (อันดับ 1 เสมอ)
PICK=random
# โหมดอัด: stepped (30fps เนียนเป๊ะ ค่าเริ่มต้น) | realtime (อัดตามเวลาจริง สำหรับ debug)
RECORD_MODE=stepped
# บังคับอัดคอมโพเนนต์ตัวเดียวเจาะจง (ลิงก์หน้า component บน 21st.dev)
FORCE_URL=
# 1 = ทำคลิปแต่ไม่โพสต์จริง
DRY_RUN=
