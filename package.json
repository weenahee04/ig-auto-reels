{
  "name": "ig-auto-reels",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Auto-record featured UI components from 21st.dev and publish them as Instagram Reels with full credit to the author",
  "scripts": {
    "scrape": "node src/cli.js scrape",
